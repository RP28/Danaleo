{
    "eda": {
        "sample_size": 30,
        "numeric_semantic_types": {
            "duration": {
                "patterns": [
                    "(?P<value>\\d+(\\.\\d+)?)\\s*(years?|yrs?|y|months?|mo)",
                    "(?P<value_min>\\d+)-(?P<value_max>\\d+)\\s*(years?|yrs?|y|months?|mo)"
                ],
                "unit_map": {
                    "year": 1,
                    "yr": 1,
                    "y": 1,
                    "month": 0.08333333333333333,
                    "mo": 0.08333333333333333,
                    "months": 0.08333333333333333
                }
            },
            "distance": {
                "patterns": [
                    "(?P<value>\\d+(\\.\\d+)?)\\s*(km|kilometers?|m|meters?|cm|centimeters?|miles?)"
                ],
                "unit_map": {
                    "km": 1000,
                    "kilometer": 1000,
                    "m": 1,
                    "meter": 1,
                    "cm": 0.01,
                    "centimeter": 0.01,
                    "mile": 1609.34
                }
            },
            "percent": {
                "patterns": [
                    "(?P<value>\\d+(\\.\\d+)?)\\s*%",
                    "(?P<value>\\d+(\\.\\d+)?)\\s*percent"
                ],
                "unit_map": {
                    "%": 0.01,
                    "percent": 0.01
                }
            }
        }
    }
}